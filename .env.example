# Copy this file to .env and fill in your keys.

# --- TEXT PROVIDER: choose ONE (Gemini takes priority if both are set) ---

# Option A: DeepSeek generates all lesson text, quizzes, paths and coach replies.
DEEPSEEK_API_KEY=sk-your-key-here

# Option B: Google Gemini. One key powers BOTH the lesson text AND real generated
# images (Gemini's native image model) for slides. Get a key at aistudio.google.com.
# When set, Gemini replaces DeepSeek for all text.
GEMINI_API_KEY=your-gemini-key-here
# GEMINI_TEXT_MODEL=gemini-3.5-flash
# GEMINI_IMAGE_MODEL=gemini-3.1-flash-image

PORT=3000

# Optional but recommended for production (Vercel): Postgres persistence.
# If set, users, games, and home suggestion caches are stored in Postgres.
# DATABASE_URL from Vercel Postgres works directly.
# DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# REQUIRED in production: secret used to sign auth tokens. With NODE_ENV=production
# the server refuses to start unless this (or DATABASE_URL) is set, so it never
# signs tokens with the public default. Keep it stable so users stay signed in
# across restarts/instances. Generate one with: openssl rand -hex 32
# AUTH_TOKEN_SECRET=change-this-to-a-long-random-secret

# Optional: let CLAUDE draw each slide's SVG diagram (accurate, labelled sketches).
# DeepSeek still writes the lesson text + quiz; when this key is set, Claude
# illustrates every slide fresh, using that slide's concept, level and the
# learner's progress. Leave unset to use DeepSeek's own SVG instead.
# Get a key from https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-your-key
# ANTHROPIC_MODEL=claude-opus-4-8

# Optional: AI IMAGE generation for slide illustrations.
# DeepSeek is text-only, so real generated images need a separate provider.
# Defaults target the OpenAI images API (gpt-image-1); any OpenAI-compatible
# images endpoint that returns b64_json or url works. Leave IMAGE_API_KEY unset
# to disable images (slides then use SVG diagrams, LaTeX and code instead).
# IMAGE_API_KEY=sk-your-image-provider-key
# IMAGE_API_URL=https://api.openai.com/v1/images/generations
# IMAGE_API_MODEL=gpt-image-1
